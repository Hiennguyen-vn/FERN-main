DB_URL=jdbc:postgresql://127.0.0.1:${POSTGRES_PORT:-5432}/${POSTGRES_DB:-fern}
# Read-only standby for reporting and other explicitly replica-safe reads only.
DB_REPLICA_URL=jdbc:postgresql://127.0.0.1:${POSTGRES_REPLICA_PORT:-5433}/${POSTGRES_DB:-fern}
DB_POOL_SIZE=16
REDIS_HOST=127.0.0.1
REDIS_PORT=${REDIS_PORT:-6379}
REDIS_POOL_SIZE=8
KAFKA_BOOTSTRAP=127.0.0.1:${KAFKA_PORT:-9092}
MASTER_NODE_URL=http://127.0.0.1:${MASTER_NODE_PORT:-8082}
AUTH_SERVICE_URL=http://127.0.0.1:${AUTH_SERVICE_PORT:-8081}
ORG_SERVICE_URL=http://127.0.0.1:${ORG_SERVICE_PORT:-8083}
HR_SERVICE_URL=http://127.0.0.1:${HR_SERVICE_PORT:-8084}
PRODUCT_SERVICE_URL=http://127.0.0.1:${PRODUCT_SERVICE_PORT:-8085}
PROCUREMENT_SERVICE_URL=http://127.0.0.1:${PROCUREMENT_SERVICE_PORT:-8086}
SALES_SERVICE_URL=http://127.0.0.1:${SALES_SERVICE_PORT:-8087}
INVENTORY_SERVICE_URL=http://127.0.0.1:${INVENTORY_SERVICE_PORT:-8088}
PAYROLL_SERVICE_URL=http://127.0.0.1:${PAYROLL_SERVICE_PORT:-8089}
FINANCE_SERVICE_URL=http://127.0.0.1:${FINANCE_SERVICE_PORT:-8090}
AUDIT_SERVICE_URL=http://127.0.0.1:${AUDIT_SERVICE_PORT:-8091}
REPORT_SERVICE_URL=http://127.0.0.1:${REPORT_SERVICE_PORT:-8092}
STRICT_INTERNAL_SERVICE_TOKEN=${INTERNAL_SERVICE_TOKEN:-}
DEV_INTERNAL_SERVICE_TOKEN=${INTERNAL_SERVICE_TOKEN:-}
INTERNAL_SERVICE_TOKEN=${INTERNAL_SERVICE_TOKEN:-}
INTERNAL_SERVICE_ALLOWLIST=gateway,master-node,auth-service,org-service,hr-service,product-service,procurement-service,sales-service,inventory-service,payroll-service,finance-service,audit-service,report-service,infra-smoke
JWT_SECRET=${JWT_SECRET:-}
AUTH_COOKIE_NAME=${AUTH_COOKIE_NAME:-dorabets_session}
AUTH_COOKIE_SECURE=${AUTH_COOKIE_SECURE:-false}
AUTH_COOKIE_SAME_SITE=${AUTH_COOKIE_SAME_SITE:-Lax}
GATEWAY_CORS_ALLOWED_ORIGINS=http://localhost:8080,http://127.0.0.1:8080,http://localhost:5173,http://127.0.0.1:5173,http://localhost:3000,http://127.0.0.1:3000
GATEWAY_CORS_ALLOWED_METHODS=GET,POST,PUT,PATCH,DELETE,OPTIONS
GATEWAY_CORS_ALLOWED_HEADERS=Authorization,Content-Type,X-Correlation-ID
GATEWAY_CORS_EXPOSED_HEADERS=X-Correlation-ID,X-Gateway-Upstream-Service
TOKEN_VERIFIER_URL=
TOKEN_SIDECAR_URL=
CONTROL_HEARTBEAT_LEASE_SECONDS=30
CONTROL_HEARTBEAT_INTERVAL_SECONDS=10
JAVA_OPTS=
