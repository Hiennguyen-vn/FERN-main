' Domain: Inventory
' Scope: Stock balance, movement, waste, and stock-count session use cases.
' Sources: services/inventory-service/src/main/java/com/fern/services/inventory/api/InventoryController.java; docs/frontend-readiness.md.
' Note: derived from source code.

@startuml
title FERN Use Case - Inventory
left to right direction

skinparam shadowing false
skinparam packageStyle rectangle
skinparam actorStyle awesome
skinparam backgroundColor #FFFFFF
skinparam usecase {
  BackgroundColor #F7FAFC
  BorderColor #2B4C7E
  ArrowColor #425466
  FontColor #16324F
}
skinparam actor {
  BorderColor #425466
  FontColor #16324F
}
skinparam note {
  BackgroundColor #FFF8E1
  BorderColor #C28A00
}

actor "Nhân viên\nStaff" as ACT_STAFF
actor "Quản lý outlet / khu vực\nOutlet / Regional Manager" as ACT_MANAGER
actor "Quản trị hệ thống\nAdmin" as ACT_ADMIN

ACT_MANAGER --|> ACT_STAFF
ACT_ADMIN --|> ACT_STAFF

rectangle "FERN ERP Platform\nInventory" as SYS_INV {
  usecase "UC-INV-01\nXem tồn kho theo item\nGet Stock Balance" as UC_INV_01
  usecase "UC-INV-02\nTra cứu tồn kho\nList Stock Balances" as UC_INV_02
  usecase "UC-INV-03\nTra cứu biến động kho\nList Inventory Transactions" as UC_INV_03
  usecase "UC-INV-04\nGhi nhận hao hụt\nCreate Waste Record" as UC_INV_04
  usecase "UC-INV-05\nTạo phiên kiểm kê\nCreate Stock Count Session" as UC_INV_05
  usecase "UC-INV-06\nTra cứu phiên kiểm kê\nList Stock Count Sessions" as UC_INV_06
  usecase "UC-INV-07\nXem chi tiết kiểm kê\nGet Stock Count Session Detail" as UC_INV_07
  usecase "UC-INV-08\nGhi sổ kiểm kê\nPost Stock Count Session" as UC_INV_08
}

ACT_STAFF --> UC_INV_01
ACT_STAFF --> UC_INV_02
ACT_STAFF --> UC_INV_03
ACT_STAFF --> UC_INV_04
ACT_STAFF --> UC_INV_05
ACT_STAFF --> UC_INV_06
ACT_STAFF --> UC_INV_07

ACT_MANAGER --> UC_INV_08
ACT_ADMIN --> UC_INV_08

note right of SYS_INV
  derived from source code
  Primary source:
  - InventoryController.java
  Supporting source:
  - docs/frontend-readiness.md
end note

@enduml
