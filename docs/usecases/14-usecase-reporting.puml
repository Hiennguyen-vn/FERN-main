rectangle "FERN ERP Platform\nReporting" as SYS_RPT {
  usecase "UC-RPT-01\nXem dashboard vận hành\nView Operational Dashboard" as UC_RPT_01
  usecase "UC-RPT-02\nXem báo cáo doanh số\nView Sales Report" as UC_RPT_02
  usecase "UC-RPT-03\nXem báo cáo chi phí\nView Expense Report" as UC_RPT_03
  usecase "UC-RPT-04\nXem báo cáo biến động kho\nView Inventory Movement Report" as UC_RPT_04
