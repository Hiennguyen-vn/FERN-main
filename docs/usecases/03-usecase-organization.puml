  usecase "UC-ORG-03\nTra cứu danh sách outlet\nList Outlets" as UC_ORG_03
  usecase "UC-ORG-04\nXem chi tiết outlet\nGet Outlet Detail" as UC_ORG_04
  usecase "UC-ORG-05\nXem cây tổ chức\nView Organization Hierarchy" as UC_ORG_05
  usecase "UC-ORG-06\nTra cứu tỷ giá\nFind Exchange Rate" as UC_ORG_06
  usecase "UC-ORG-07\nTạo outlet\nCreate Outlet" as UC_ORG_07
  usecase "UC-ORG-08\nCập nhật tỷ giá\nUpsert Exchange Rate" as UC_ORG_08
}

ACT_STAFF --> UC_ORG_01
ACT_STAFF --> UC_ORG_02
ACT_STAFF --> UC_ORG_03
ACT_STAFF --> UC_ORG_04
ACT_STAFF --> UC_ORG_05
ACT_STAFF --> UC_ORG_06

ACT_ADMIN --> UC_ORG_07
ACT_ADMIN --> UC_ORG_08

note right of SYS_ORG
  derived from source code
  Primary source:
