actor "Quản lý outlet / khu vực\nOutlet / Regional Manager" as ACT_MANAGER
actor "Quản trị hệ thống\nAdmin" as ACT_ADMIN

rectangle "FERN ERP Platform\nCRM" as SYS_CRM {
  usecase "UC-CRM-01\nTra cứu khách hàng\nList / Search Customers" as UC_CRM_01
}

ACT_CASHIER --> UC_CRM_01
ACT_MANAGER --> UC_CRM_01
ACT_ADMIN --> UC_CRM_01

